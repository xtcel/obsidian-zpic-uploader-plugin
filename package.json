    "@rollup/plugin-typescript": "^11.0.0",
    "@types/node": "^20.0.0",
    "obsidian": "^1.4.0",
    "rollup": "^4.0.0",
    "tslib": "^2.6.0",
    "typescript": "^5.0.0"
