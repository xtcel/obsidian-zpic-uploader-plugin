{
  "name": "obsidian-zpic-uploader-plugin",
  "version": "0.1.2",
  "description": "Zpic-Uploader plugin for Obsidian (paste and drag-and-drop).",
  "main": "main.js",
  "scripts": {
    "dev": "rollup -c -w",
    "build": "rollup -c --environment NODE_ENV:production",
